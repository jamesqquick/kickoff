---
import AppLayout from "@/layouts/AppLayout.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn, teamColorGradient, getTournamentStatus, teamStatusClass, tournamentStatusClass, tournamentStatusLabel } from "@/lib/utils";
import PageHeader from "@/components/PageHeader.astro";
import StatCard from "@/components/StatCard.astro";
import SectionCard from "@/components/SectionCard.astro";
import TeamCrest from "@/components/TeamCrest.astro";
import { makeTeamService } from "@/services/team-service";
import { makeTournamentService } from "@/services/tournament-service";

const user = Astro.locals.user;
if (!user || user.role !== "admin") {
  return Astro.redirect("/");
}

const [allTeams, allTournaments] = await Promise.all([
  makeTeamService().listTeams(),
  makeTournamentService().listTournaments(),
]);

const recentTeams = [...allTeams]
  .sort((a, b) => b.createdAt - a.createdAt)
  .slice(0, 5);

const recentTournaments = [...allTournaments]
  .sort((a, b) => (b.startDate ?? "").localeCompare(a.startDate ?? ""))
  .slice(0, 5);

const pendingCount = allTeams.filter((t) => t.status === "pending").length;


---

<AppLayout title="Admin" activeNav="admin">
  <div class="p-4 sm:p-6 lg:p-8">
    <PageHeader
      eyebrow="Admin"
      title="Dashboard"
      subtitle="Overview of teams and tournaments."
    />

    <!-- Stat cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
      <StatCard
        icon="🛡️"
        value={String(allTeams.length)}
        label="Total Teams"
      />
      <StatCard
        icon="⏳"
        value={String(pendingCount)}
        label="Pending Approvals"
        color={pendingCount > 0 ? "text-(--color-warn)" : "text-(--color-foreground)"}
      />
      <StatCard
        icon="🏆"
        value={String(allTournaments.length)}
        label="Tournaments"
      />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Recent teams -->
      <SectionCard title="Recent Teams">
        <a
          slot="header-action"
          href="/admin/teams"
          class="text-xs text-(--color-primary) hover:underline"
        >
          View all →
        </a>

        {recentTeams.length === 0 ? (
          <p class="px-6 py-8 text-sm text-(--color-muted) text-center">No teams yet.</p>
        ) : (
          <ul>
            {recentTeams.map((team) => (
              <li class="border-b border-(--color-border-soft) last:border-0">
                <a
                  href={`/admin/teams/${team.id}`}
                  class="flex items-center gap-3 px-5 py-3 hover:bg-(--color-background) transition-colors"
                >
                  <TeamCrest
                    initials={team.name.slice(0, 2).toUpperCase()}
                    gradient={teamColorGradient(team.color)}
                    size="sm"
                  />
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-(--color-foreground) truncate">{team.name}</p>
                    <p class="text-xs text-(--color-muted)">{team.city} · {team.division}</p>
                  </div>
                  <span class={cn(
                    "shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium",
                    teamStatusClass(team.status),
                  )}>
                    {team.status.charAt(0).toUpperCase() + team.status.slice(1)}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </SectionCard>

      <!-- Recent tournaments -->
      <SectionCard title="Recent Tournaments">
        <a
          slot="header-action"
          href="/admin/tournaments"
          class="text-xs text-(--color-primary) hover:underline"
        >
          View all →
        </a>

        {recentTournaments.length === 0 ? (
          <p class="px-6 py-8 text-sm text-(--color-muted) text-center">No tournaments yet.</p>
        ) : (
          <ul>
            {recentTournaments.map((t) => {
              const status = getTournamentStatus(t);
              return (
                <li class="border-b border-(--color-border-soft) last:border-0">
                  <a
                    href={`/admin/tournaments/${t.id}/edit`}
                    class="flex items-center gap-3 px-5 py-3 hover:bg-(--color-background) transition-colors"
                  >
                    <div class="w-9 h-9 rounded-[9px] bg-(--color-primary-subtle) flex items-center justify-center text-base shrink-0">
                      🏆
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-(--color-foreground) truncate">{t.name}</p>
                      <p class="text-xs text-(--color-muted)">
                        {t.startDate && t.endDate
                          ? `${t.startDate} – ${t.endDate}`
                          : t.startDate ?? "No dates set"}
                      </p>
                    </div>
                  <span class={cn(
                    "shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium",
                    tournamentStatusClass(status),
                  )}>
                      {tournamentStatusLabel(status)}
                    </span>
                  </a>
                </li>
              );
            })}
          </ul>
        )}
      </SectionCard>

    </div>
  </div>
</AppLayout>

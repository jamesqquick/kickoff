---
import AppLayout from "@/layouts/AppLayout.astro";
import PageHeader from "@/components/PageHeader.astro";

const user = Astro.locals.user;
if (!user || user.role !== "admin") return Astro.redirect("/");
---

<AppLayout title="Schedule" activeNav="admin-schedule">
  <div class="p-4 sm:p-6 lg:p-8">
    <PageHeader
      title="Schedule"
      subtitle="All upcoming matches across every tournament."
    />
    <p class="text-sm text-(--color-muted) mt-6">Schedule coming soon.</p>
  </div>
</AppLayout>

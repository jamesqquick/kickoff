---
import AppLayout from "@/layouts/AppLayout.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import PageHeader from "@/components/PageHeader.astro";
import AdminBreadcrumb from "@/components/AdminBreadcrumb.astro";
import SectionCard from "@/components/SectionCard.astro";
import { RegistrationReviewTable } from "@/components/RegistrationReviewTable";
import { makeTournamentService } from "@/services/tournament-service";
import { makeTournamentRegistrationService } from "@/services/tournament-registration-service";
import { NotFoundError } from "@/lib/errors";

const user = Astro.locals.user;
if (!user || user.role !== "admin") {
  return Astro.redirect("/");
}

const { id } = Astro.params;

let tournament;
let registrations;
try {
  tournament = await makeTournamentService().getTournament(id!);
  registrations = await makeTournamentRegistrationService().getRegistrationsForTournament(id!);
} catch (err) {
  if (err instanceof NotFoundError) {
    return Astro.redirect("/admin/tournaments");
  }
  throw err;
}
---

<AppLayout title={`Registrations — ${tournament.name}`} activeNav="admin-tournaments">
  <div class="p-4 sm:p-6 lg:p-8 max-w-5xl">
    <AdminBreadcrumb crumbs={[
      { label: "Admin",           href: "/admin" },
      { label: "Tournaments",     href: "/admin/tournaments" },
      { label: tournament.name,   href: `/admin/tournaments/${tournament.id}/edit` },
      { label: "Registrations" },
    ]} />

    <div class="flex items-start justify-between gap-4 mb-6">
      <PageHeader
        title="Team Registrations"
        subtitle={`${registrations.length} registration${registrations.length !== 1 ? "s" : ""} for ${tournament.name}`}
      />
      <a href={`/admin/tournaments/${tournament.id}/edit`} class={cn(buttonVariants({ variant: "outline" }), "shrink-0 mt-1")}>
        ← Edit Tournament
      </a>
    </div>

    <SectionCard class="p-5 sm:p-7">
      {registrations.length === 0 ? (
        <p class="text-sm text-(--color-muted) text-center py-8">
          No teams have registered yet.
        </p>
      ) : (
        <RegistrationReviewTable
          client:load
          initialRegistrations={registrations}
        />
      )}
    </SectionCard>
  </div>
</AppLayout>

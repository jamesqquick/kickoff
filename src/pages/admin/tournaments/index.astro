---
import AppLayout from "@/layouts/AppLayout.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn, getTournamentStatus, tournamentStatusClass, tournamentStatusLabel } from "@/lib/utils";
import PageHeader from "@/components/PageHeader.astro";
import AdminBreadcrumb from "@/components/AdminBreadcrumb.astro";
import SectionCard from "@/components/SectionCard.astro";
import { makeTournamentService } from "@/services/tournament-service";
import { DeleteTournamentButton } from "@/components/DeleteTournamentButton";

const user = Astro.locals.user;
if (!user || user.role !== "admin") {
  return Astro.redirect("/");
}

const tournaments = await makeTournamentService().listTournaments();
---

<AppLayout title="Admin — Tournaments" activeNav="admin-tournaments">
  <div class="p-4 sm:p-6 lg:p-8">
    <AdminBreadcrumb crumbs={[
      { label: "Admin", href: "/admin" },
      { label: "Tournaments" },
    ]} />

    <PageHeader
      eyebrow="Admin"
      title="Tournaments"
      subtitle="Manage tournaments and dates."
    >
      <div slot="actions">
        <a href="/admin/tournaments/new" class={cn(buttonVariants({ variant: "default" }), "h-9 px-4")}>
          + New Tournament
        </a>
      </div>
    </PageHeader>

    {tournaments.length === 0 ? (
      <SectionCard class="p-12 text-center">
        <p class="text-(--color-muted) text-sm">No tournaments yet.</p>
        <a href="/admin/tournaments/new" class={cn(buttonVariants({ variant: "default" }), "mt-4 inline-flex")}>
          Create the first tournament
        </a>
      </SectionCard>
    ) : (
      <SectionCard>
        <table class="w-full">
          <thead>
            <tr class="border-b border-(--color-border)">
              <th class="text-left text-xs font-semibold uppercase tracking-wider text-(--color-muted-fg) px-5 py-3">Name</th>
              <th class="hidden sm:table-cell text-left text-xs font-semibold uppercase tracking-wider text-(--color-muted-fg) px-5 py-3">Status</th>
              <th class="hidden md:table-cell text-left text-xs font-semibold uppercase tracking-wider text-(--color-muted-fg) px-5 py-3">Dates</th>
              <th class="px-5 py-3"></th>
            </tr>
          </thead>
          <tbody>
            {tournaments.map((t) => {
              const status = getTournamentStatus(t);
              return (
                <tr class="border-b border-(--color-border-soft) last:border-0 hover:bg-(--color-background) transition-colors">
                  <td class="px-5 py-3.5">
                    <span class="font-semibold text-sm text-(--color-foreground)">{t.name}</span>
                    <p class="text-xs text-(--color-muted) sm:hidden mt-0.5">
                      <span class={cn("inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium", tournamentStatusClass(status))}>
                        {tournamentStatusLabel(status)}
                      </span>
                    </p>
                  </td>
                  <td class="hidden sm:table-cell px-5 py-3.5">
                    <span class={cn("inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium", tournamentStatusClass(status))}>
                      {tournamentStatusLabel(status)}
                    </span>
                  </td>
                  <td class="hidden md:table-cell px-5 py-3.5 text-sm text-(--color-muted)">
                    {t.startDate && t.endDate
                      ? `${t.startDate} – ${t.endDate}`
                      : t.startDate
                        ? `From ${t.startDate}`
                        : "—"}
                  </td>
                  <td class="px-5 py-3.5 text-right">
                    <div class="flex items-center justify-end gap-2">
                      <a
                        href={`/admin/tournaments/${t.id}/edit`}
                        class={cn(buttonVariants({ variant: "outline" }), "h-7 px-3 text-xs")}
                      >
                        Edit
                      </a>
                      {status !== "active" && (
                        <DeleteTournamentButton
                          client:load
                          tournamentId={t.id}
                          tournamentName={t.name}
                        />
                      )}
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </SectionCard>
    )}
  </div>
</AppLayout>

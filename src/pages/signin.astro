---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import BrandMark from "@/components/BrandMark.astro";
import FormField from "@/components/FormField.astro";
import GoogleAuthButton from "@/components/GoogleAuthButton.astro";

const GOOGLE_OAUTH_URL = redirectTo
  ? `/api/auth/signin/google?redirect=${encodeURIComponent(redirectTo)}`
  : "/api/auth/signin/google";

// API routes redirect back here with ?tab=signup&error=... on failure.
const activeTab = Astro.url.searchParams.get("tab") === "signup" ? "signup" : "signin";
const error = Astro.url.searchParams.get("error");
const signInError = activeTab === "signin" ? error : null;
const signUpError = activeTab === "signup" ? error : null;

// Post-auth redirect: preserved through hidden form fields → API routes → Location header.
// Only same-origin paths are accepted — the API routes validate and strip external URLs.
const redirectTo = Astro.url.searchParams.get("redirect") ?? "";
---

<BaseLayout title="Sign In">
  <div class="min-h-screen grid grid-cols-1 lg:grid-cols-2">
    <!-- Left: branding panel — hidden on mobile/tablet -->
    <div
      class="hidden lg:flex relative flex-col justify-between p-14 border-r border-(--color-border) overflow-hidden"
      style="background: radial-gradient(circle at 30% 20%, rgba(5,150,105,0.16), transparent 45%), radial-gradient(circle at 80% 80%, rgba(234,88,12,0.12), transparent 45%), #ffffff;"
    >
      <div class="absolute -bottom-32 -right-20 w-[340px] h-[340px] rounded-full" style="border: 2px solid rgba(5,150,105,0.12);" />

      <!-- Logo -->
      <div class="flex items-center gap-2.5 relative z-10">
        <BrandMark size="md" />
        <span class="font-display font-bold text-xl text-(--color-foreground)">Kickoff</span>
      </div>

      <!-- Hero copy -->
      <div class="relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-(--color-primary) mb-4">
          Tournament Operations, Simplified
        </p>
        <h1 class="font-display text-[42px] leading-[1.1] text-(--color-foreground) max-w-sm">
          Run your soccer tournament like a pro.
        </h1>
        <p class="mt-5 text-(--color-muted) text-[15px] max-w-[400px] leading-relaxed">
          Register teams, manage rosters, build schedules, and track every
          match — all from one clean dashboard built for organizers and coaches.
        </p>
      </div>

      <p class="text-xs text-(--color-muted-fg) relative z-10">© 2026 Kickoff · Spring Invitational Cup</p>
    </div>

    <!-- Right: form panel -->
    <div class="flex items-center justify-center p-6 sm:p-10 bg-(--color-background)">
      <div class="w-full max-w-[400px]">
        <!-- Brand mark — mobile only (branding panel is hidden) -->
        <div class="flex items-center gap-2 mb-8 lg:hidden">
          <BrandMark size="sm" />
          <span class="font-display font-bold text-lg text-(--color-foreground)">Kickoff</span>
        </div>

        <!-- Tab switcher -->
        <div id="tab-bar" class="flex gap-1 p-1 rounded-lg border border-(--color-border) bg-[#eef2f7] mb-7">
          <button
            id="tab-signin"
            onclick="switchTab('signin')"
            class={cn(
              buttonVariants({ variant: "ghost" }),
              "flex-1",
              activeTab === "signin"
                ? "bg-white text-(--color-foreground) shadow-sm"
                : "bg-[#e8ecf2] text-(--color-muted)"
            )}
          >Sign In</button>
          <button
            id="tab-signup"
            onclick="switchTab('signup')"
            class={cn(
              buttonVariants({ variant: "ghost" }),
              "flex-1",
              activeTab === "signup"
                ? "bg-white text-(--color-foreground) shadow-sm"
                : "bg-[#e8ecf2] text-(--color-muted)"
            )}
          >Sign Up</button>
        </div>

        <!-- ── SIGN IN ── -->
        <div id="panel-signin" class={activeTab === "signup" ? "hidden" : ""}>
          <h2 class="font-display text-2xl font-semibold text-(--color-foreground) mb-1">Welcome back</h2>
          <p class="text-sm text-(--color-muted) mb-6">
            {redirectTo.startsWith("/join/")
              ? "Sign in to join the team. You'll be taken back automatically."
              : "Sign in to manage your teams and tournaments."}
          </p>

          <GoogleAuthButton label="Continue with Google" href={GOOGLE_OAUTH_URL} />

          <div class="flex items-center gap-3 my-5 text-sm text-(--color-muted)">
            <span class="flex-1 h-px bg-[#c5cdd9]" />
            or sign in with email
            <span class="flex-1 h-px bg-[#c5cdd9]" />
          </div>

          <form method="POST" action="/api/auth/signin">
            <input type="hidden" name="redirect" value={redirectTo} />
            {signInError && (
              <p class="text-sm text-red-600 mb-4 p-3 rounded-md bg-red-50 border border-red-200">
                {signInError}
              </p>
            )}
            <div class="space-y-4">
              <FormField
                label="Email"
                type="email"
                name="email"
                placeholder="you@email.com"
              />
              <div>
                <div class="flex justify-between items-center mb-1.5">
                  <label class="text-sm font-medium text-(--color-foreground)">Password</label>
                  <a href="#" class="text-xs text-(--color-muted) hover:text-(--color-primary)">Forgot?</a>
                </div>
                <FormField
                  type="password"
                  name="password"
                  placeholder="Your password"
                />
              </div>
              <button
                type="submit"
                class={cn(buttonVariants({ variant: "default", size: "xl" }), "w-full")}
              >
                Sign In →
              </button>
            </div>
          </form>
        </div>

        <!-- ── SIGN UP ── -->
        <div id="panel-signup" class={activeTab === "signin" ? "hidden" : ""}>
          <h2 class="font-display text-2xl font-semibold text-(--color-foreground) mb-1">Create an account</h2>
          <p class="text-sm text-(--color-muted) mb-6">
            {redirectTo.startsWith("/join/")
              ? "Create a free account to join the team. You'll be added automatically."
              : "Join Kickoff to manage teams and tournaments."}
          </p>

          <GoogleAuthButton label="Sign up with Google" href={GOOGLE_OAUTH_URL} />

          <div class="flex items-center gap-3 my-5 text-sm text-(--color-muted)">
            <span class="flex-1 h-px bg-[#c5cdd9]" />
            or create an account
            <span class="flex-1 h-px bg-[#c5cdd9]" />
          </div>

          <form method="POST" action="/api/auth/signup">
            <input type="hidden" name="redirect" value={redirectTo} />
            {signUpError && (
              <p class="text-sm text-red-600 mb-4 p-3 rounded-md bg-red-50 border border-red-200">
                {signUpError}
              </p>
            )}
            <div class="space-y-4">
              <div class="grid grid-cols-2 gap-3">
                <FormField
                  label="First name"
                  type="text"
                  name="firstName"
                  placeholder="Alex"
                  required
                />
                <FormField
                  label="Last name"
                  type="text"
                  name="lastName"
                  placeholder="Morgan"
                  required
                />
              </div>
              <FormField
                label="Email"
                type="email"
                name="email"
                placeholder="you@email.com"
                required
              />
              <FormField
                label="Password"
                type="password"
                name="password"
                placeholder="Create a password (min. 8 chars)"
                minlength={8}
                required
              />
              <label class="flex items-start gap-2 text-sm text-(--color-muted) cursor-pointer">
                <input type="checkbox" class="w-4 h-4 accent-(--color-primary) mt-0.5 shrink-0" />
                I agree to the Terms of Service and Privacy Policy
              </label>
              <button
                type="submit"
                class={cn(buttonVariants({ variant: "default", size: "xl" }), "w-full")}
              >
                Create Account →
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  function switchTab(tab: string) {
    const signin = document.getElementById("panel-signin")!;
    const signup = document.getElementById("panel-signup")!;
    const tabSignin = document.getElementById("tab-signin")!;
    const tabSignup = document.getElementById("tab-signup")!;

    if (tab === "signin") {
      signin.classList.remove("hidden");
      signup.classList.add("hidden");
      tabSignin.classList.add("bg-white", "shadow-sm", "text-(--color-foreground)");
      tabSignin.classList.remove("bg-[#e8ecf2]", "text-(--color-muted)");
      tabSignup.classList.add("bg-[#e8ecf2]", "text-(--color-muted)");
      tabSignup.classList.remove("bg-white", "shadow-sm", "text-(--color-foreground)");
    } else {
      signup.classList.remove("hidden");
      signin.classList.add("hidden");
      tabSignup.classList.add("bg-white", "shadow-sm", "text-(--color-foreground)");
      tabSignup.classList.remove("bg-[#e8ecf2]", "text-(--color-muted)");
      tabSignin.classList.add("bg-[#e8ecf2]", "text-(--color-muted)");
      tabSignin.classList.remove("bg-white", "shadow-sm", "text-(--color-foreground)");
    }
  }
  (window as any).switchTab = switchTab;
</script>

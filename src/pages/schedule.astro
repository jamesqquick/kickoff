---
import AppLayout from "@/layouts/AppLayout.astro";
import PageHeader from "@/components/PageHeader.astro";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/signin");
---

<AppLayout title="My Schedule" activeNav="schedule">
  <div class="p-4 sm:p-6 lg:p-8">
    <PageHeader
      title="My Schedule"
      subtitle="Upcoming matches across all your teams."
    />
    <p class="text-sm text-(--color-muted) mt-6">Schedule coming soon.</p>
  </div>
</AppLayout>

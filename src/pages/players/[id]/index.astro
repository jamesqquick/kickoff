---
import AppLayout from "@/layouts/AppLayout.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import { makePlayerService } from "@/services/player-service";
import { NotFoundError } from "@/lib/errors";

const { id } = Astro.params;

let player;
try {
  player = await makePlayerService().getPlayerWithProfile(id!);
} catch (err) {
  if (err instanceof NotFoundError) {
    return Astro.redirect("/players");
  }
  throw err;
}

const joinedDate = new Date(player.createdAt).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<AppLayout title={player.name} activeNav="players">
  <div class="p-4 sm:p-6 lg:p-8">
    <!-- Breadcrumb -->
    <p class="text-sm text-(--color-muted) mb-5">
      <a href="/players" class="hover:text-(--color-primary)">Players</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-foreground)">{player.name}</span>
    </p>

    <!-- Hero banner -->
    <div
      class="relative rounded-xl border border-(--color-border) overflow-hidden p-5 sm:p-7 mb-6 flex flex-col sm:flex-row items-start sm:items-center gap-5 sm:gap-6"
      style="background: radial-gradient(circle at 15% 30%, rgba(59,130,246,0.12), transparent 40%), radial-gradient(circle at 85% 70%, rgba(139,92,246,0.10), transparent 45%), #ffffff;"
    >
      {player.image ? (
        <img
          src={player.image}
          alt={player.name}
          class="w-20 h-20 rounded-full object-cover shadow-lg shrink-0"
        />
      ) : (
        <div class="w-20 h-20 rounded-full bg-(--color-primary) flex items-center justify-center text-white text-2xl font-bold shadow-lg shrink-0">
          {player.name.slice(0, 2).toUpperCase()}
        </div>
      )}

      <div class="flex-1 min-w-0">
        <h1 class="font-display text-2xl sm:text-3xl font-bold text-(--color-foreground) mb-1">
          {player.name}
        </h1>
        <p class="text-sm text-(--color-muted)">
          Joined {joinedDate}
          <!-- TODO: show team name once player-team assignment is implemented -->
        </p>
      </div>

      <div class="flex sm:flex-col gap-2 shrink-0">
        <button class={cn(buttonVariants({ variant: "outline" }), "h-9 px-4")}>
          Share Profile
        </button>
      </div>
    </div>

    <!-- Team assignment — placeholder until roster slice is implemented -->
    <div class="rounded-xl border border-(--color-border) bg-(--color-card)">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between px-4 sm:px-6 py-4 gap-3 border-b border-(--color-border)">
        <h3 class="font-display font-semibold text-(--color-foreground)">Team</h3>
      </div>
      <div class="px-6 py-8 text-center text-sm text-(--color-muted)">
        Team assignment coming soon. <!-- TODO: player_teams slice -->
      </div>
    </div>
  </div>
</AppLayout>

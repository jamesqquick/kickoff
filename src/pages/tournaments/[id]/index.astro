---
import AppLayout from "@/layouts/AppLayout.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn, getTournamentStatus } from "@/lib/utils";
import RegistrationStatusBadge from "@/components/RegistrationStatusBadge.astro";
import PageHeader from "@/components/PageHeader.astro";
import SectionCard from "@/components/SectionCard.astro";
import { DivisionAccordion } from "@/components/DivisionAccordion";
import { makeTournamentService } from "@/services/tournament-service";
import { makeDivisionService } from "@/services/division-service";
import { makeTeamService } from "@/services/team-service";
import { TournamentRegistrationRepository } from "@/repositories/tournament-registration-repository";
import { getDb } from "@/lib/db";
import { NotFoundError } from "@/lib/errors";

const { id } = Astro.params;
const user = Astro.locals.user;

let tournament;
let divisions;
try {
  tournament = await makeTournamentService().getTournament(id!);
  divisions = await makeDivisionService().getDivisionsForTournament(id!);
} catch (err) {
  if (err instanceof NotFoundError) {
    return Astro.redirect("/tournaments");
  }
  throw err;
}

const status = getTournamentStatus(tournament);

const coachTeams = user ? await makeTeamService().listByCoach(user.id) : [];

const regRepo = new TournamentRegistrationRepository(getDb());
const existingReg = user && coachTeams.length > 0
  ? await Promise.all(
      coachTeams.map((t) => regRepo.findByTeamAndTournament(t.id, tournament.id))
    ).then((results) => results.find(Boolean) ?? null)
  : null;

// Fetch all registrations and group by division for the accordion.
const allRegistrations = await regRepo.listByTournament(tournament.id);

const divisionsWithTeams = divisions.map((d) => {
  const teams = allRegistrations
    .filter((r) => r.divisionId === d.id)
    .map((r) => ({
      teamId: r.teamId,
      teamName: r.teamName,
      teamColor: r.teamColor,
      teamShortName: r.teamShortName,
      status: r.status,
    }));
  return { ...d, count: teams.filter((t) => t.status === "approved").length, teams };
});

const deadlinePassed = tournament.registrationDeadline
  ? new Date() > new Date(tournament.registrationDeadline)
  : false;

const canRegister = !existingReg && user && coachTeams.length > 0 && !deadlinePassed && status === "upcoming";



const justRegistered = Astro.url.searchParams.get("registered") === "1";

function formatDate(d: string | null) {
  if (!d) return null;
  return new Date(d).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}
---

<AppLayout title={tournament.name} activeNav="tournaments">
  <div class="p-4 sm:p-6 lg:p-8 max-w-4xl">

    <!-- Breadcrumb -->
    <p class="text-sm text-(--color-muted) mb-5">
      <a href="/tournaments" class="hover:text-(--color-primary)">Tournaments</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-foreground)">{tournament.name}</span>
    </p>

    <!-- Success banner — shown immediately after submitting a registration -->
    {justRegistered && (
      <div class="mb-6 rounded-lg border border-emerald-200 bg-emerald-50 dark:border-emerald-800 dark:bg-emerald-900/20 px-5 py-4 flex items-center gap-3">
        <span class="text-emerald-600 dark:text-emerald-400 text-lg">✓</span>
        <div>
          <p class="text-sm font-semibold text-emerald-800 dark:text-emerald-300">Registration submitted — pending review</p>
          <p class="text-xs text-emerald-700 dark:text-emerald-400 mt-0.5">An admin will review your registration and confirm your spot.</p>
        </div>
      </div>
    )}

    <!-- Header — tournament identity + action CTAs only -->
    <div class="flex items-start justify-between gap-4 mb-6">
      <div>
        <h1 class="font-display text-2xl sm:text-3xl font-bold text-(--color-foreground) mb-1">
          {tournament.name}
        </h1>

      </div>

      <div class="flex items-center gap-2 shrink-0 flex-wrap justify-end">
        {canRegister && (
          <a href={`/tournaments/${tournament.id}/register`} class={cn(buttonVariants({ variant: "default" }), "h-9 px-4")}>
            Register Your Team →
          </a>
        )}
        {!user && !deadlinePassed && status === "upcoming" && (
          <a href={`/signin?redirect=/tournaments/${tournament.id}`} class={cn(buttonVariants({ variant: "default" }), "h-9 px-4")}>
            Sign in to Register
          </a>
        )}
        {user && coachTeams.length === 0 && !deadlinePassed && status === "upcoming" && (
          <a href="/teams/register" class={cn(buttonVariants({ variant: "default" }), "h-9 px-4")}>
            Create a Team to Register
          </a>
        )}
        {user?.role === "admin" && (
          <a
            href={`/admin/tournaments/${tournament.id}/edit`}
            class={cn(buttonVariants({ variant: "outline" }), "h-9 px-4")}
          >
            Edit →
          </a>
        )}
      </div>
    </div>


    {tournament.description && (
      <SectionCard class="p-5 mb-6">
        <p class="text-sm text-(--color-foreground)">{tournament.description}</p>
      </SectionCard>
    )}

    <!-- Details card -->
    <SectionCard class="p-5 sm:p-6 mb-6">
      <h2 class="font-display text-lg font-semibold text-(--color-foreground) mb-4">Details</h2>
      <dl class="space-y-2 text-sm">
        {(tournament.startDate || tournament.endDate) && (
          <div class="flex gap-2">
            <dt class="font-semibold text-(--color-foreground) shrink-0">Dates</dt>
            <dd class="text-(--color-muted)">
              {tournament.startDate && tournament.endDate
                ? `${formatDate(tournament.startDate)} – ${formatDate(tournament.endDate)}`
                : tournament.startDate
                ? `From ${formatDate(tournament.startDate)}`
                : formatDate(tournament.endDate)}
            </dd>
          </div>
        )}
        {tournament.location && (
          <div class="flex gap-2">
            <dt class="font-semibold text-(--color-foreground) shrink-0">Location</dt>
            <dd class="text-(--color-muted)">{tournament.location}</dd>
          </div>
        )}
        <div class="flex items-center gap-2">
          <dt class="font-semibold text-(--color-foreground) shrink-0">Registration</dt>
          <dd class="flex items-center gap-2">
            <span class="text-(--color-muted)">
              {tournament.registrationDeadline
                ? (status === "upcoming" && !deadlinePassed)
                  ? `Closes ${formatDate(tournament.registrationDeadline)}`
                  : `Closed ${formatDate(tournament.registrationDeadline)}`
                : status === "past"
                ? "Closed"
                : status === "active"
                ? "Closed"
                : "No deadline set"}
            </span>
            <RegistrationStatusBadge open={status === "upcoming" && !deadlinePassed} />
          </dd>
        </div>
      </dl>
    </SectionCard>

    <!-- Divisions -->
    <SectionCard class="p-5 sm:p-7">
      <h2 class="font-display text-lg font-semibold text-(--color-foreground) mb-1">Divisions</h2>
      <p class="text-sm text-(--color-muted) mb-5">
        {status === "past"
          ? "This tournament has ended."
          : status === "active"
          ? "This tournament is happening now. Registration is closed."
          : deadlinePassed
          ? "Registration has closed for this tournament."
          : "Choose your division when you register."}
      </p>

      <DivisionAccordion
        client:load
        divisions={divisionsWithTeams}
      />
    </SectionCard>
  </div>
</AppLayout>

---
import AppLayout from "@/layouts/AppLayout.astro";
import { getTournamentStatus } from "@/lib/utils";
import PageHeader from "@/components/PageHeader.astro";
import { makeTournamentService } from "@/services/tournament-service";

const tournaments = await makeTournamentService().listTournaments();

const active   = tournaments.filter((t) => getTournamentStatus(t) === "active");
const upcoming = tournaments.filter((t) => getTournamentStatus(t) === "upcoming");
const past     = tournaments.filter((t) => getTournamentStatus(t) === "past");

function formatDate(d: string): string {
  return new Date(d).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}

function formatDates(t: (typeof tournaments)[number]): string {
  if (t.startDate && t.endDate) return `${formatDate(t.startDate)} – ${formatDate(t.endDate)}`;
  if (t.startDate) return `From ${formatDate(t.startDate)}`;
  return "Dates TBD";
}
---

<AppLayout title="Tournaments" activeNav="tournaments">
  <div class="p-4 sm:p-6 lg:p-8">
    <PageHeader
      title="Tournaments"
      subtitle="Browse tournaments open for registration and upcoming events."
    />

    {tournaments.length === 0 ? (
      <div class="rounded-xl border border-(--color-border) bg-(--color-card) p-12 text-center">
        <p class="text-(--color-muted) text-sm">No tournaments have been created yet.</p>
      </div>
    ) : (
      <div class="space-y-8">
        {active.length > 0 && (
          <section>
            <h2 class="text-xs font-semibold uppercase tracking-wider text-(--color-muted-fg) mb-3">Happening Now</h2>
            <div class="rounded-xl border border-(--color-border) bg-(--color-card) divide-y divide-(--color-border-soft)">
              {active.map((t) => (
                <a href={`/tournaments/${t.id}`} class="flex items-center justify-between gap-4 px-5 py-4 hover:bg-(--color-card-hover) transition-colors">
                  <div>
                    <p class="font-semibold text-sm text-(--color-foreground)">{t.name}</p>
                    <p class="text-xs text-(--color-muted) mt-0.5">{formatDates(t)}</p>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

        {upcoming.length > 0 && (
          <section>
            <h2 class="text-xs font-semibold uppercase tracking-wider text-(--color-muted-fg) mb-3">Upcoming</h2>
            <div class="rounded-xl border border-(--color-border) bg-(--color-card) divide-y divide-(--color-border-soft)">
              {upcoming.map((t) => (
                <a href={`/tournaments/${t.id}`} class="flex items-center justify-between gap-4 px-5 py-4 hover:bg-(--color-card-hover) transition-colors">
                  <div>
                    <p class="font-semibold text-sm text-(--color-foreground)">{t.name}</p>
                    <p class="text-xs text-(--color-muted) mt-0.5">{formatDates(t)}</p>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

        {past.length > 0 && (
          <section>
            <h2 class="text-xs font-semibold uppercase tracking-wider text-(--color-muted-fg) mb-3">Past</h2>
            <div class="rounded-xl border border-(--color-border) bg-(--color-card) divide-y divide-(--color-border-soft)">
              {past.map((t) => (
                <a href={`/tournaments/${t.id}`} class="flex items-center justify-between gap-4 px-5 py-4 opacity-70 hover:bg-(--color-card-hover) hover:opacity-100 transition-all">
                  <div>
                    <p class="font-semibold text-sm text-(--color-foreground)">{t.name}</p>
                    <p class="text-xs text-(--color-muted) mt-0.5">{formatDates(t)}</p>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>
    )}
  </div>
</AppLayout>

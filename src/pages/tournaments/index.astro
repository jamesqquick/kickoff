---
import AppLayout from "@/layouts/AppLayout.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn, getTournamentStatus } from "@/lib/utils";
import PageHeader from "@/components/PageHeader.astro";
import { makeTournamentService } from "@/services/tournament-service";

const tournaments = await makeTournamentService().listTournaments();

const active = tournaments.filter((t) => getTournamentStatus(t) === "active");
const upcoming = tournaments.filter((t) => getTournamentStatus(t) === "upcoming");
const past = tournaments.filter((t) => getTournamentStatus(t) === "past");

const statusLabel = { upcoming: "Upcoming", active: "Live", past: "Past" };

const statusClass: Record<string, string> = {
  upcoming: "bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400",
  active: "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300",
  past: "bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300",
};

function formatDates(t: (typeof tournaments)[number]): string {
  if (t.startDate && t.endDate) return `${t.startDate} – ${t.endDate}`;
  if (t.startDate) return `From ${t.startDate}`;
  return "Dates TBD";
}
---

<AppLayout title="Tournaments" activeNav="tournaments">
  <div class="p-4 sm:p-6 lg:p-8">
    <PageHeader
      title="Tournaments"
      subtitle="Browse active and upcoming tournaments."
    />

    {tournaments.length === 0 ? (
      <div class="rounded-xl border border-(--color-border) bg-(--color-card) p-12 text-center">
        <p class="text-(--color-muted) text-sm">No tournaments have been created yet.</p>
      </div>
    ) : (
      <div class="space-y-8">
        {active.length > 0 && (
          <section>
            <h2 class="text-xs font-semibold uppercase tracking-wider text-(--color-muted-fg) mb-3">Live Now</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {active.map((t) => (
                <div class="rounded-xl border border-emerald-200 dark:border-emerald-800 bg-(--color-card) p-5 flex flex-col gap-3">
                  <div class="flex items-start justify-between gap-2">
                    <h3 class="font-display font-semibold text-(--color-foreground)">{t.name}</h3>
                    <span class={cn("shrink-0 inline-block rounded-full px-2 py-0.5 text-xs font-medium", statusClass["active"])}>
                      {statusLabel["active"]}
                    </span>
                  </div>
                  <p class="text-sm text-(--color-muted)">{formatDates(t)}</p>
                  <a
                    href="/teams"
                    class={cn(buttonVariants({ variant: "default" }), "mt-auto h-8 px-3 text-xs w-full justify-center")}
                  >
                    View Teams →
                  </a>
                </div>
              ))}
            </div>
          </section>
        )}

        {upcoming.length > 0 && (
          <section>
            <h2 class="text-xs font-semibold uppercase tracking-wider text-(--color-muted-fg) mb-3">Upcoming</h2>
            <div class="rounded-xl border border-(--color-border) bg-(--color-card) divide-y divide-(--color-border-soft)">
              {upcoming.map((t) => (
                <div class="flex items-center justify-between gap-4 px-5 py-4">
                  <div>
                    <p class="font-semibold text-sm text-(--color-foreground)">{t.name}</p>
                    <p class="text-xs text-(--color-muted) mt-0.5">{formatDates(t)}</p>
                  </div>
                  <span class={cn("shrink-0 inline-block rounded-full px-2 py-0.5 text-xs font-medium", statusClass["upcoming"])}>
                    {statusLabel["upcoming"]}
                  </span>
                </div>
              ))}
            </div>
          </section>
        )}

        {past.length > 0 && (
          <section>
            <h2 class="text-xs font-semibold uppercase tracking-wider text-(--color-muted-fg) mb-3">Past</h2>
            <div class="rounded-xl border border-(--color-border) bg-(--color-card) divide-y divide-(--color-border-soft)">
              {past.map((t) => (
                <div class="flex items-center justify-between gap-4 px-5 py-4 opacity-70">
                  <div>
                    <p class="font-semibold text-sm text-(--color-foreground)">{t.name}</p>
                    <p class="text-xs text-(--color-muted) mt-0.5">{formatDates(t)}</p>
                  </div>
                  <span class={cn("shrink-0 inline-block rounded-full px-2 py-0.5 text-xs font-medium", statusClass["past"])}>
                    {statusLabel["past"]}
                  </span>
                </div>
              ))}
            </div>
          </section>
        )}
      </div>
    )}
  </div>
</AppLayout>

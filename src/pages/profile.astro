---
import AppLayout from "@/layouts/AppLayout.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import PageHeader from "@/components/PageHeader.astro";
import SectionCard from "@/components/SectionCard.astro";
import FormField from "@/components/FormField.astro";
import { SaveProfileButton } from "@/components/SaveProfileButton";
import { makeProfileService } from "@/services/profile-service";
import { makeTeamMemberService } from "@/services/team-member-service";
import { badgeVariants } from "@/components/ui/badge";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/");

// Split the stored name into first / last for the form fields.
const nameParts = (user.name ?? "").trim().split(/\s+/);
const firstName = nameParts[0] ?? "";
const lastName = nameParts.slice(1).join(" ");

// Load extended profile (may be null for new users — form renders empty).
const profileData = await makeProfileService().getProfile(user.id);

// Load the user's team memberships for the My Teams section.
const myTeams = await makeTeamMemberService().listByUser(user.id);
---

<AppLayout title="My Profile" activeNav="profile">
  <div class="p-4 sm:p-6 lg:p-8">
    <PageHeader title="My Profile" subtitle="Manage your account and preferences.">
      <SaveProfileButton slot="actions" client:load />
    </PageHeader>

    <div class="grid grid-cols-1 xl:grid-cols-[1fr_360px] gap-6">
      <!-- Left: personal info -->
      <div class="space-y-5">
        <SectionCard class="p-5 sm:p-6">
          <h3 class="font-display font-semibold text-(--color-foreground) mb-5">Personal Information</h3>

          <!-- Avatar -->
          <div class="flex items-center gap-4 mb-6">
            {user.image ? (
              <img
                src={user.image}
                alt={user.name ?? ""}
                class="w-[72px] h-[72px] rounded-full object-cover shrink-0"
              />
            ) : (
              <div class="w-[72px] h-[72px] rounded-full flex items-center justify-center text-[26px] font-bold text-white bg-gradient-to-br from-orange-500 to-orange-700 shrink-0">
                {(firstName[0] ?? "").toUpperCase()}{(lastName[0] ?? "").toUpperCase()}
              </div>
            )}
            <div>
              <button class={cn(buttonVariants({ variant: "outline" }), "h-8 px-3")}>Upload photo</button>
              <p class="text-xs text-(--color-muted-fg) mt-1.5">JPG or PNG, max 2MB.</p>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <FormField label="First name" name="firstName" value={firstName} />
            <FormField label="Last name"  name="lastName"  value={lastName} />
          </div>
          <FormField label="Email" type="email" value={user.email} class="mb-4" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <FormField label="Phone"         name="phone"       placeholder="(512) 555-0000" value={profileData?.phone ?? ""} />
            <FormField label="Date of birth" name="dateOfBirth" type="date" value={profileData?.dateOfBirth ?? ""} />
          </div>

          <div class="h-px bg-(--color-border) my-5" />
          <h4 class="text-sm font-semibold text-(--color-foreground) mb-4">Address</h4>

          <FormField label="Street address"     name="addressStreet" value={profileData?.addressStreet ?? ""} class="mb-4" />
          <FormField label="Apt / Suite / Unit" name="addressApt"    value={profileData?.addressApt ?? ""} placeholder="Optional" class="mb-4" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <FormField label="City"  name="addressCity"  value={profileData?.addressCity ?? ""} />
            <FormField label="State" name="addressState" value={profileData?.addressState ?? ""} />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <FormField label="ZIP code" name="addressZip" value={profileData?.addressZip ?? ""} />
            <FormField label="Country">
              <select
                name="addressCountry"
                class="w-full h-10 px-3 rounded-md border border-(--color-border) bg-(--color-surface) text-sm focus:outline-none focus:ring-2 focus:ring-(--color-primary) focus:ring-offset-1"
              >
                {["United States", "Canada", "Mexico"].map((c) => (
                  <option selected={c === (profileData?.addressCountry ?? "United States")}>{c}</option>
                ))}
              </select>
            </FormField>
          </div>
        </SectionCard>
      </div>

      <!-- Right rail -->
      <div class="space-y-5">
        <!-- My Teams -->
        <SectionCard class="p-5">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-display font-semibold text-(--color-foreground)">My Teams</h3>
            <a href="/teams" class={cn(buttonVariants({ variant: "outline" }), "h-7 px-3 text-xs")}>+ Join a Team</a>
          </div>

          {myTeams.length === 0 ? (
            <div class="text-center py-4">
              <p class="text-sm text-(--color-muted) mb-3">You haven't joined a team yet.</p>
              <a href="/teams" class={cn(buttonVariants({ variant: "default" }), "h-8 px-4 text-xs")}>
                Browse Teams
              </a>
            </div>
          ) : (
            <div class="space-y-2">
              {myTeams.map((membership) => (
                <div class="flex items-center justify-between gap-3 rounded-lg border border-(--color-border-soft) px-3 py-2.5 hover:bg-(--color-background) transition-colors">
                  <div class="min-w-0">
                    <a
                      href={`/teams/${membership.teamId}`}
                      class="font-medium text-sm text-(--color-foreground) hover:text-(--color-primary) truncate block"
                    >
                      {membership.teamName}
                    </a>
                    <p class="text-xs text-(--color-muted) truncate">{membership.teamDivision} · {membership.teamCity}</p>
                  </div>
                  <span class={badgeVariants({ variant: membership.status === "approved" ? "success" : "warning" })}>
                    {membership.status === "approved" ? "Active" : "Pending"}
                  </span>
                </div>
              ))}
            </div>
          )}
        </SectionCard>
      </div>
    </div>
  </div>
</AppLayout>

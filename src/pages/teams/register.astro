---
import AppLayout from "@/layouts/AppLayout.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import PageHeader from "@/components/PageHeader.astro";
import SectionCard from "@/components/SectionCard.astro";
import FormField from "@/components/FormField.astro";
import { CrestPicker } from "@/components/CrestPicker";
import { RegisterTeamButton } from "@/components/RegisterTeamButton";
---

<AppLayout title="Register Team" activeNav="teams">
  <div class="p-4 sm:p-6 lg:p-8 max-w-3xl">
    <PageHeader
      eyebrow="Spring Invitational Cup"
      title="Register a Team"
      subtitle="Enter your team's info to get started. Division, roster, and payment come next."
    />

    <SectionCard class="p-5 sm:p-7">
      <h2 class="font-display text-lg font-semibold text-(--color-foreground) mb-1">Team Info</h2>
      <p class="text-sm text-(--color-muted) mb-6">
        This is how your team appears on schedules and the public bracket.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <FormField label="Team name" name="name" required placeholder="e.g. FC Velocity" />
        <FormField label="Home city" name="city" required placeholder="e.g. Austin, TX" />
      </div>

      <CrestPicker client:load />

      <!--
        TODO: Division selection
        Replace this hidden placeholder with a real radio picker once division data
        is stored on the team record and seeded from the tournament config.
        The action already accepts `division: string` — just wire the value through.
      -->
      <input type="hidden" name="division" value="TBD" />

      <div class="flex justify-end pt-2">
        <RegisterTeamButton client:load />
      </div>
    </SectionCard>
  </div>
</AppLayout>

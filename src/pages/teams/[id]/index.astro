---
import AppLayout from "@/layouts/AppLayout.astro";
import { buttonVariants } from "@/components/ui/button";
import { badgeVariants } from "@/components/ui/badge";
import { cn } from "@/lib/utils";
import TeamCrest from "@/components/TeamCrest.astro";
import { makeTeamService } from "@/services/team-service";
import { NotFoundError } from "@/lib/errors";
import { teamStatusVariant } from "@/lib/utils";

const { id } = Astro.params;

let team;
try {
  team = await makeTeamService().getTeam(id!);
} catch (err) {
  if (err instanceof NotFoundError) {
    return Astro.redirect("/teams");
  }
  throw err;
}
---

<AppLayout title={team.name} activeNav="teams">
  <div class="p-4 sm:p-6 lg:p-8">
    <!-- Breadcrumb -->
    <p class="text-sm text-(--color-muted) mb-5">
      <a href="/teams" class="hover:text-(--color-primary)">Teams</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-foreground)">{team.name}</span>
    </p>

    <!-- Hero banner -->
    <div
      class="relative rounded-xl border border-(--color-border) overflow-hidden p-5 sm:p-7 mb-6 flex flex-col sm:flex-row items-start sm:items-center gap-5 sm:gap-6"
      style="background: radial-gradient(circle at 15% 30%, rgba(5,150,105,0.18), transparent 40%), radial-gradient(circle at 85% 70%, rgba(234,88,12,0.12), transparent 45%), #ffffff;"
    >
      <TeamCrest
        initials={team.name.slice(0, 2).toUpperCase()}
        gradient="from-emerald-500 to-emerald-700"
        size="2xl"
        class="shadow-lg shrink-0"
      />
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-3 mb-1">
          <h1 class="font-display text-2xl sm:text-3xl font-bold text-(--color-foreground)">{team.name}</h1>
          <span class={badgeVariants({ variant: teamStatusVariant(team.status) })}>
            ● {team.status.charAt(0).toUpperCase() + team.status.slice(1)}
          </span>
        </div>
        <p class="text-sm text-(--color-muted)">
          {team.city} · {team.division}
          <!-- TODO: resolve coach name via User/Player slice -->
        </p>
      </div>
      <div class="flex sm:flex-col gap-2 shrink-0">
        <button class={cn(buttonVariants({ variant: "default" }), "h-9 px-4")}>Edit Team</button>
        <button class={cn(buttonVariants({ variant: "outline" }), "h-9 px-4")}>Share Profile</button>
      </div>
    </div>

    <!-- Roster table — static until Players slice is implemented -->
    <div class="rounded-xl border border-(--color-border) bg-(--color-card)">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between px-4 sm:px-6 py-4 gap-3 border-b border-(--color-border)">
        <h3 class="font-display font-semibold text-(--color-foreground)">
          Squad Roster <span class="font-normal text-sm text-(--color-muted)"><!-- TODO: PlayerService --></span>
        </h3>
        <button class={cn(buttonVariants({ variant: "default" }), "h-8 px-3 text-xs shrink-0")}>+ Add Player</button>
      </div>
      <div class="px-6 py-8 text-center text-sm text-(--color-muted)">
        Roster management coming soon. <!-- TODO: PlayerService + PlayerRepository -->
      </div>
    </div>
  </div>
</AppLayout>

---
import AppLayout from "@/layouts/AppLayout.astro";
import { buttonVariants } from "@/components/ui/button";
import { badgeVariants } from "@/components/ui/badge";
import { cn } from "@/lib/utils";
import TeamCrest from "@/components/TeamCrest.astro";
import { makeTeamService } from "@/services/team-service";
import { makeTeamMemberService } from "@/services/team-member-service";
import { makeTeamInviteService } from "@/services/team-invite-service";
import { TeamMemberRepository } from "@/repositories/team-member-repository";
import { getDb } from "@/lib/db";
import { NotFoundError } from "@/lib/errors";
import { teamStatusVariant, teamColorGradient } from "@/lib/utils";
import { JoinTeamButton } from "@/components/JoinTeamButton";
import { TeamMemberPanel } from "@/components/TeamMemberPanel";
import { InviteLinkPanel } from "@/components/InviteLinkPanel";

const { id } = Astro.params;
const user = Astro.locals.user;

let team;
try {
  team = await makeTeamService().getTeam(id!);
} catch (err) {
  if (err instanceof NotFoundError) {
    return Astro.redirect("/teams");
  }
  throw err;
}

const isOwnerOrAdmin =
  user?.role === "admin" || user?.id === team.coachId;

const roster = await makeTeamMemberService().listByTeam(id!);
const pendingRequests = isOwnerOrAdmin
  ? await makeTeamMemberService().listPendingByTeam(id!, user!)
  : [];

// Resolve the current user's join status to seed the island's initial state.
type JoinStatus = "none" | "pending" | "approved";
let myStatus: JoinStatus = "none";
if (user) {
  const existing = await new TeamMemberRepository(getDb()).findByUserAndTeam(
    user.id,
    team.id,
  );
  if (existing) {
    myStatus = existing.status as JoinStatus;
  }
}

// Resolve the invite link for coaches — create one lazily if it doesn't exist yet.
let inviteUrl: string | null = null;
if (isOwnerOrAdmin && user) {
  try {
    const invite = await makeTeamInviteService().getOrCreate(team.id, user);
    inviteUrl = `${Astro.url.origin}/join/${invite.token}`;
  } catch {
    // Non-fatal — the panel simply won't render.
  }
}

---

<AppLayout title={team.name} activeNav="teams">
  <div class="p-4 sm:p-6 lg:p-8">
    <!-- Breadcrumb -->
    <p class="text-sm text-(--color-muted) mb-5">
      <a href="/teams" class="hover:text-(--color-primary)">Teams</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-foreground)">{team.name}</span>
    </p>

    <!-- Hero banner -->
    <div
      class="relative rounded-xl border border-(--color-border) overflow-hidden p-5 sm:p-7 mb-6 flex flex-col sm:flex-row items-start sm:items-center gap-5 sm:gap-6"
      style="background: radial-gradient(circle at 15% 30%, rgba(5,150,105,0.18), transparent 40%), radial-gradient(circle at 85% 70%, rgba(234,88,12,0.12), transparent 45%), #ffffff;"
    >
      <TeamCrest
        initials={team.shortName ?? team.name.slice(0, 2).toUpperCase()}
        gradient={teamColorGradient(team.color)}
        size="2xl"
        class="shadow-lg shrink-0"
      />
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-3 mb-1">
          <h1 class="font-display text-2xl sm:text-3xl font-bold text-(--color-foreground)">{team.name}</h1>
          <span class={badgeVariants({ variant: teamStatusVariant(team.status) })}>
            ● {team.status.charAt(0).toUpperCase() + team.status.slice(1)}
          </span>
        </div>
        <p class="text-sm text-(--color-muted)">
          {team.city} · {team.division}
        </p>
        <p class="text-xs text-(--color-muted) mt-0.5">
          Coach: {team.coachName}
        </p>
      </div>
      <div class="flex sm:flex-col gap-2 shrink-0">
        {isOwnerOrAdmin ? (
          <>
            <a href={`/teams/${team.id}/edit`} class={cn(buttonVariants({ variant: "default" }), "h-9 px-4")}>Edit Team</a>
            <button class={cn(buttonVariants({ variant: "outline" }), "h-9 px-4")}>Share Profile</button>
          </>
        ) : user ? (
          <JoinTeamButton client:load teamId={team.id} initialStatus={myStatus} />
        ) : (
          <a href="/signin" class={cn(buttonVariants({ variant: "default" }), "h-9 px-4")}>
            Sign in to Join
          </a>
        )}
      </div>
    </div>

    {isOwnerOrAdmin && inviteUrl && (
      <InviteLinkPanel
        client:load
        teamId={team.id}
        initialInviteUrl={inviteUrl}
      />
    )}

    <TeamMemberPanel
      client:load
      initialRoster={roster}
      pendingRequests={pendingRequests}
      isOwnerOrAdmin={isOwnerOrAdmin}
    />
  </div>
</AppLayout>

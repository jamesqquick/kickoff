---
import AppLayout from "@/layouts/AppLayout.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import TeamCrest from "@/components/TeamCrest.astro";
import { makeTeamService } from "@/services/team-service";
import { makeTeamMemberService } from "@/services/team-member-service";
import { makeTeamInviteService } from "@/services/team-invite-service";
import { TeamMemberRepository } from "@/repositories/team-member-repository";
import { getDb } from "@/lib/db";
import { NotFoundError } from "@/lib/errors";
import { teamColorGradient } from "@/lib/utils";
import { JoinTeamButton } from "@/components/JoinTeamButton";
import { TeamMemberPanel } from "@/components/TeamMemberPanel";
import { makeTournamentRegistrationService } from "@/services/tournament-registration-service";
import { makeDivisionService } from "@/services/division-service";
import { makeTournamentService } from "@/services/tournament-service";
import SectionCard from "@/components/SectionCard.astro";
import { InviteLinkPanel } from "@/components/InviteLinkPanel";
import { WelcomeBanner } from "@/components/WelcomeBanner";

const { id } = Astro.params;
const user = Astro.locals.user;

let team;
try {
  team = await makeTeamService().getTeam(id!);
} catch (err) {
  if (err instanceof NotFoundError) {
    return Astro.redirect("/teams");
  }
  throw err;
}

const isOwnerOrAdmin =
  user?.role === "admin" || user?.id === team.coachId;

const justJoined = Astro.url.searchParams.get("joined") === "1";

const roster = await makeTeamMemberService().listByTeam(id!);
const pendingRequests = isOwnerOrAdmin
  ? await makeTeamMemberService().listPendingByTeam(id!, user!)
  : [];

// Resolve the current user's join status to seed the island's initial state.
type JoinStatus = "none" | "pending" | "approved";
let myStatus: JoinStatus = "none";
if (user) {
  const existing = await new TeamMemberRepository(getDb()).findByUserAndTeam(
    user.id,
    team.id,
  );
  if (existing) {
    myStatus = existing.status as JoinStatus;
  }
}

// Tournament registrations for this team.
const registrations = await makeTournamentRegistrationService().getRegistrationsForTeam(team.id);
// Enrich with division name + tournament name for display.
const enrichedRegs = await Promise.all(
  registrations.map(async (r) => {
    const [division, tournament] = await Promise.all([
      makeDivisionService().getDivision(r.divisionId),
      makeTournamentService().getTournament(r.tournamentId),
    ]);
    return { ...r, divisionName: division.name, tournamentName: tournament.name, tournamentId: tournament.id };
  })
);

// Resolve the invite link for the coach/admin.
let inviteUrl: string | null = null;
if (isOwnerOrAdmin && user) {
  try {
    const invite = await makeTeamInviteService().getOrCreate(team.id, user);
    inviteUrl = `${Astro.url.origin}/join/${invite.token}`;
  } catch {
    // Non-fatal — the panel simply won't render.
  }
}

---

<AppLayout title={team.name} activeNav="teams">
  <div class="p-4 sm:p-6 lg:p-8">
    {justJoined && (
      <WelcomeBanner client:load teamName={team.name} />
    )}

    <!-- Breadcrumb -->
    <p class="text-sm text-(--color-muted) mb-5">
      <a href="/teams" class="hover:text-(--color-primary)">Teams</a>
      <span class="mx-2">/</span>
      <span class="text-(--color-foreground)">{team.name}</span>
    </p>

    <!-- Hero banner -->
    <div
      class="relative rounded-xl border border-(--color-border) overflow-hidden p-5 sm:p-7 mb-6 flex flex-col sm:flex-row items-start sm:items-center gap-5 sm:gap-6"
      style="background: radial-gradient(circle at 15% 30%, rgba(5,150,105,0.18), transparent 40%), radial-gradient(circle at 85% 70%, rgba(234,88,12,0.12), transparent 45%), #ffffff;"
    >
      <TeamCrest
        initials={team.shortName ?? team.name.slice(0, 2).toUpperCase()}
        gradient={teamColorGradient(team.color)}
        size="2xl"
        class="shadow-lg shrink-0"
      />
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-3 mb-1">
          <h1 class="font-display text-2xl sm:text-3xl font-bold text-(--color-foreground)">{team.name}</h1>
        </div>
        <p class="text-sm text-(--color-muted)">
          {team.city}
        </p>
        <p class="text-xs text-(--color-muted) mt-0.5">
          Coach: {team.coachName}
        </p>
      </div>
      <div class="flex sm:flex-col gap-2 shrink-0">
        {isOwnerOrAdmin ? (
          <>
            <a href={`/teams/${team.id}/edit`} class={cn(buttonVariants({ variant: "default" }), "h-9 px-4")}>Edit Team</a>
            <button class={cn(buttonVariants({ variant: "outline" }), "h-9 px-4")}>Share Profile</button>
          </>
        ) : user ? (
          <JoinTeamButton client:load teamId={team.id} initialStatus={myStatus} />
        ) : (
          <a href="/signin" class={cn(buttonVariants({ variant: "default" }), "h-9 px-4")}>
            Sign in to Join
          </a>
        )}
      </div>
    </div>

    {isOwnerOrAdmin && inviteUrl && (
      <InviteLinkPanel
        client:load
        teamId={team.id}
        initialInviteUrl={inviteUrl}
      />
    )}

    <TeamMemberPanel
      client:load
      teamId={team.id}
      initialRoster={roster}
      pendingRequests={pendingRequests}
      isOwnerOrAdmin={isOwnerOrAdmin}
    />

    <!-- Tournament Registrations -->
    {enrichedRegs.length > 0 && (
      <SectionCard class="p-5 sm:p-7 mt-6">
        <h2 class="font-display text-lg font-semibold text-(--color-foreground) mb-1">Tournaments</h2>
        <p class="text-sm text-(--color-muted) mb-4">This team's tournament registrations.</p>
        <div class="divide-y divide-(--color-border-soft) rounded-lg border border-(--color-border)">
          {enrichedRegs.map((r) => (
            <div class="flex items-center justify-between gap-4 px-4 py-3">
              <div>
                <a
                  href={`/tournaments/${r.tournamentId}`}
                  class="font-medium text-sm text-(--color-foreground) hover:text-(--color-primary) transition-colors"
                >
                  {r.tournamentName}
                </a>
                <p class="text-xs text-(--color-muted) mt-0.5">{r.divisionName}</p>
              </div>
              <span class={
                r.status === "approved"   ? "inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300" :
                r.status === "waitlisted" ? "inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300" :
                r.status === "rejected"   ? "inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300" :
                                            "inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300"
              }>
                {r.status.charAt(0).toUpperCase() + r.status.slice(1)}
              </span>
            </div>
          ))}
        </div>
      </SectionCard>
    )}
  </div>
</AppLayout>

---
import AppLayout from "@/layouts/AppLayout.astro";
import { buttonVariants } from "@/components/ui/button";
import { badgeVariants } from "@/components/ui/badge";
import { cn } from "@/lib/utils";
import PageHeader from "@/components/PageHeader.astro";
import SectionCard from "@/components/SectionCard.astro";
import StatCard from "@/components/StatCard.astro";
import TeamCrest from "@/components/TeamCrest.astro";
import MatchCard from "@/components/MatchCard.astro";
---

<AppLayout title="Dashboard" activeNav="dashboard">
  <div class="p-8">
    <PageHeader
      eyebrow="Spring Invitational Cup"
      title="Tournament Dashboard"
      subtitle="March 14–22, 2026 · Live now"
    >
      <div slot="actions" class="flex items-center gap-3">
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-(--color-muted-fg) text-sm">🔍</span>
          <input
            placeholder="Search teams, players..."
            class="h-9 pl-9 pr-4 rounded-md border border-(--color-border) bg-(--color-surface) text-sm w-64 focus:outline-none focus:ring-2 focus:ring-(--color-primary) focus:ring-offset-1"
          />
        </div>
        <button class={cn(buttonVariants({ variant: "outline" }), "h-9 px-3")}>Export</button>
        <a href="/tournaments/new" class="h-9 px-4 rounded-md bg-(--color-primary) text-white text-sm font-semibold flex items-center hover:bg-(--color-primary-hover) transition-colors">+ New Tournament</a>
      </div>
    </PageHeader>

    <!-- Stat cards -->
    <div class="grid grid-cols-4 gap-4 mb-6">
      {[
        { icon: "🛡️", value: "128",    label: "Registered Teams", trend: "▲ 12 this week", trendColor: "text-(--color-primary)", badge: "Live", badgeVariant: "live" },
        { icon: "👥", value: "1,940",  label: "Total Players",     trend: "▲ 184 this week", trendColor: "text-(--color-primary)" },
        { icon: "⚽", value: "312",    label: "Matches Scheduled", trend: "48 completed",    trendColor: "text-(--color-muted)" },
        { icon: "💰", value: "$38.4k", label: "Revenue",           trend: "7 payments pending", trendColor: "text-(--color-warn)" },
      ].map((s) => (
        <StatCard
          icon={s.icon}
          value={s.value}
          label={s.label}
          trend={s.trend}
          trendColor={s.trendColor}
          badge={s.badge}
          badgeVariant={s.badgeVariant as any}
        />
      ))}
    </div>

    <!-- Main content grid -->
    <div class="grid grid-cols-[1fr_320px] gap-5">
      <div class="space-y-5">
        <!-- Pending approvals -->
        <SectionCard title="Pending Approvals">
          <span slot="header-action" class={badgeVariants({ variant: "warning" })}>7 awaiting review</span>
          <table class="w-full">
            <thead>
              <tr class="border-b border-(--color-border)">
                {["Team", "Division", "Roster", "Payment", ""].map((h) => (
                  <th class="text-left text-xs font-semibold uppercase tracking-wider text-(--color-muted-fg) px-6 py-3">{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {[
                { initials: "RV", name: "Real Valley",  gradient: "from-violet-600 to-violet-900", division: "U18 Men's",     roster: "18/18", rosterV: "success",     payment: "Paid",    payV: "success" },
                { initials: "AC", name: "Atlas City",   gradient: "from-sky-500 to-blue-700",      division: "Open Women's",  roster: "14/18", rosterV: "warning",     payment: "Paid",    payV: "success" },
                { initials: "TF", name: "Toro FC",      gradient: "from-red-500 to-red-800",       division: "U16 Boys",      roster: "20/22", rosterV: "success",     payment: "Unpaid",  payV: "destructive" },
                { initials: "GS", name: "Green Storm",  gradient: "from-emerald-500 to-emerald-800", division: "U18 Men's",   roster: "19/18", rosterV: "success",     payment: "Partial", payV: "warning" },
              ].map((row, i) => (
                <tr class="border-b border-(--color-border-soft) last:border-0 hover:bg-(--color-background) transition-colors">
                  <td class="px-6 py-3.5">
                    <div class="flex items-center gap-3">
                      <TeamCrest initials={row.initials} gradient={row.gradient} size="md" />
                      <span class="font-semibold text-sm text-(--color-foreground)">{row.name}</span>
                    </div>
                  </td>
                  <td class="px-6 py-3.5 text-sm text-(--color-muted)">{row.division}</td>
                  <td class="px-6 py-3.5">
                    <span class={badgeVariants({ variant: row.rosterV as any })}>{row.roster}</span>
                  </td>
                  <td class="px-6 py-3.5">
                    <span class={badgeVariants({ variant: row.payV as any })}>{row.payment}</span>
                  </td>
                  <td class="px-6 py-3.5 text-right">
                    {i === 0
                      ? <button class={cn(buttonVariants({ variant: "default" }), "h-7 px-3 text-xs")}>Approve</button>
                      : <button class={cn(buttonVariants({ variant: "outline" }), "h-7 px-3 text-xs")}>Review</button>
                    }
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </SectionCard>

        <!-- Today's matches -->
        <SectionCard title="Today's Matches">
          <a slot="header-action" href="/teams/1/schedule" class="text-xs text-(--color-muted) hover:text-(--color-primary)">View schedule →</a>
          <div class="divide-y divide-(--color-border-soft)">
            {[
              {
                home: { name: "FC Velocity", initials: "FV", gradient: "from-emerald-500 to-emerald-700" },
                away: { name: "Sun Bears",   initials: "SB", gradient: "from-amber-400 to-amber-600" },
                score: "2 – 1", badge: "● LIVE 63'", badgeVariant: "live", info: null,
              },
              {
                home: { name: "Real Valley", initials: "RV", gradient: "from-violet-600 to-violet-900" },
                away: { name: "Toro FC",     initials: "TF", gradient: "from-red-500 to-red-800" },
                score: "4:30 PM", badge: null, badgeVariant: null, info: "Field 3",
              },
              {
                home: { name: "Atlas City",  initials: "AC", gradient: "from-sky-500 to-blue-700" },
                away: { name: "Green Storm", initials: "GS", gradient: "from-emerald-500 to-emerald-800" },
                score: "6:00 PM", badge: null, badgeVariant: null, info: "Field 1",
              },
            ].map((m) => (
              <div class="px-4 py-3">
                <MatchCard
                  home={m.home}
                  away={m.away}
                  score={m.score}
                  badge={m.badge ?? undefined}
                  badgeVariant={m.badgeVariant as any ?? undefined}
                  info={m.info}
                  class="bg-(--color-background) px-6 py-4 rounded-lg border border-(--color-border)"
                />
              </div>
            ))}
          </div>
        </SectionCard>
      </div>

      <!-- Right column -->
      <div class="space-y-5">
        <!-- Division capacity -->
        <SectionCard class="p-5">
          <h3 class="font-display font-semibold text-(--color-foreground) mb-4">Division Capacity</h3>
          <div class="space-y-4">
            {[
              { label: "U18 Men's",    val: "30/32", pct: 94 },
              { label: "Open Women's", val: "24/32", pct: 75 },
              { label: "U16 Boys",     val: "28/32", pct: 87 },
              { label: "U16 Girls",    val: "18/32", pct: 56 },
            ].map((d) => (
              <div>
                <div class="flex justify-between text-sm mb-1.5">
                  <span class="text-(--color-foreground)">{d.label}</span>
                  <span class="text-(--color-muted)">{d.val}</span>
                </div>
                <div class="h-2 rounded-full bg-(--color-border-soft) overflow-hidden">
                  <div class="h-full rounded-full bg-(--color-primary)" style={`width: ${d.pct}%`} />
                </div>
              </div>
            ))}
          </div>
        </SectionCard>

        <!-- Recent activity -->
        <SectionCard class="p-5">
          <h3 class="font-display font-semibold text-(--color-foreground) mb-4">Recent Activity</h3>
          <div class="space-y-3">
            {[
              { initials: "RV", grad: "from-violet-600 to-violet-900", text: "Real Valley completed registration", time: "12 min ago" },
              { initials: "JD", grad: "from-amber-400 to-amber-600",   text: "J. Diaz added to Sun Bears roster", time: "40 min ago" },
              { initials: "$",  grad: "from-sky-500 to-blue-700",      text: "Payment received — Atlas City ($300)", time: "1 hr ago" },
              { initials: "⚽", grad: "from-emerald-500 to-emerald-700", text: "Match result posted — Field 2",    time: "2 hr ago" },
            ].map((a) => (
              <div class="flex items-center gap-3">
                <div class={`w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold text-white bg-gradient-to-br ${a.grad} shrink-0`}>{a.initials}</div>
                <div class="min-w-0">
                  <p class="text-sm font-medium text-(--color-foreground) leading-snug">{a.text}</p>
                  <p class="text-xs text-(--color-muted) mt-0.5">{a.time}</p>
                </div>
              </div>
            ))}
          </div>
        </SectionCard>
      </div>
    </div>
  </div>
</AppLayout>

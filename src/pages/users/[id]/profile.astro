---
import AppLayout from "@/layouts/AppLayout.astro";
import { buttonVariants } from "@/components/ui/button";
import { badgeVariants } from "@/components/ui/badge";
import { cn } from "@/lib/utils";
import PageHeader from "@/components/PageHeader.astro";
import SectionCard from "@/components/SectionCard.astro";
import TeamCrest from "@/components/TeamCrest.astro";
import FormField from "@/components/FormField.astro";
const { id } = Astro.params;
// Static mockup — real data would use `id` to fetch user profile
---

<AppLayout title="My Profile" activeNav="profile">
  <div class="p-4 sm:p-6 lg:p-8">
    <PageHeader title="My Profile" subtitle="Manage your account, address, and preferences.">
      <button slot="actions" class={cn(buttonVariants({ variant: "default" }), "h-9 px-4")}>Save Changes</button>
    </PageHeader>

    <!-- Single column on mobile/tablet, side panel at xl+ -->
    <div class="grid grid-cols-1 xl:grid-cols-[1fr_360px] gap-6">
      <!-- Left: personal info -->
      <div class="space-y-5">
        <SectionCard class="p-5 sm:p-6">
          <h3 class="font-display font-semibold text-(--color-foreground) mb-5">Personal Information</h3>

          <!-- Avatar upload -->
          <div class="flex items-center gap-4 mb-6">
            <div class="w-[72px] h-[72px] rounded-full flex items-center justify-center text-[26px] font-bold text-white bg-gradient-to-br from-orange-500 to-orange-700 shrink-0">AM</div>
            <div>
              <button class={cn(buttonVariants({ variant: "outline" }), "h-8 px-3")}>Upload photo</button>
              <p class="text-xs text-(--color-muted-fg) mt-1.5">JPG or PNG, max 2MB.</p>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <FormField label="First name" value="Alex" />
            <FormField label="Last name"  value="Morgan" />
          </div>
          <FormField label="Email" type="email" value="alex.morgan@fcvelocity.com" class="mb-4" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <FormField label="Phone"         value="(512) 555-0148" />
            <FormField label="Date of birth" type="date" value="2007-04-12" />
          </div>

          <div class="h-px bg-(--color-border) my-5" />
          <h4 class="text-sm font-semibold text-(--color-foreground) mb-4">Address</h4>

          <FormField label="Street address" value="1204 South Lamar Blvd" class="mb-4" />
          <FormField label="Apt / Suite / Unit" placeholder="Optional" class="mb-4" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <FormField label="City"  value="Austin" />
            <FormField label="State" value="TX" />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <FormField label="ZIP code" value="78704" />
            <FormField label="Country">
              <select class="w-full h-10 px-3 rounded-md border border-(--color-border) bg-(--color-surface) text-sm focus:outline-none focus:ring-2 focus:ring-(--color-primary) focus:ring-offset-1">
                <option>United States</option>
                <option>Canada</option>
                <option>Mexico</option>
              </select>
            </FormField>
          </div>
        </SectionCard>
      </div>

      <!-- Right: teams, security, notifications -->
      <div class="space-y-5">
        <!-- My teams -->
        <SectionCard class="p-5">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-display font-semibold text-(--color-foreground)">My Teams</h3>
            <button class={cn(buttonVariants({ variant: "outline" }), "h-7 px-3 text-xs")}>+ Join team</button>
          </div>
          <div class="space-y-3">
            {[
              { initials: "FV", gradient: "from-emerald-500 to-emerald-700", name: "FC Velocity",    meta: "Captain · U18 Men's · Spring Invitational Cup", statusV: "success", status: "Active" },
              { initials: "OB", gradient: "from-slate-400 to-slate-600",     name: "Old Boys United", meta: "Player · Rec League · 2024",                   statusV: "secondary", status: "Past" },
            ].map((t) => (
              <div class="flex items-center gap-3">
                <TeamCrest initials={t.initials} gradient={t.gradient} size="lg" />
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-semibold text-(--color-foreground)">{t.name}</p>
                  <p class="text-xs text-(--color-muted) truncate">{t.meta}</p>
                </div>
                <span class:list={[badgeVariants({ variant: t.statusV as any }), "shrink-0"]}>{t.status}</span>
              </div>
            ))}
          </div>
        </SectionCard>

        <!-- Account & security -->
        <SectionCard class="p-5">
          <h3 class="font-display font-semibold text-(--color-foreground) mb-4">Account &amp; Security</h3>
          <div class="space-y-4">
            <FormField label="Current password" type="password" placeholder="••••••••" />
            <FormField label="New password"      type="password" placeholder="••••••••" />
            <FormField label="Confirm new password" type="password" placeholder="••••••••" />
            <button class={cn(buttonVariants({ variant: "outline" }), "h-8 px-3")}>Update password</button>
          </div>
        </SectionCard>

        <!-- Notifications -->
        <SectionCard class="p-5">
          <h3 class="font-display font-semibold text-(--color-foreground) mb-4">Notifications</h3>
          <div class="divide-y divide-(--color-border-soft)">
            {[
              { label: "Match reminders",    checked: true },
              { label: "Roster changes",     checked: true },
              { label: "Payment receipts",   checked: false },
              { label: "Weekly digest email", checked: true },
            ].map((n) => (
              <label class="flex justify-between items-center py-3 cursor-pointer">
                <span class="text-sm text-(--color-foreground)">{n.label}</span>
                <input type="checkbox" checked={n.checked} class="w-4 h-4 accent-(--color-primary)" />
              </label>
            ))}
          </div>
        </SectionCard>
      </div>
    </div>
  </div>
</AppLayout>

---
import BrandMark from "@/components/BrandMark.astro";
import { UserMenu } from "@/components/layout/UserMenu";

interface Props {
  activeNav?: string;
}
const { activeNav = "dashboard" } = Astro.props;

const user = Astro.locals.user;
const displayName = user?.name?.trim() || user?.email || "Account";
const role = (user as { role?: string } | null)?.role ?? "Member";
const initials =
  displayName
    .split(/\s+/)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() ?? "")
    .join("") || "?";

function getIcon(name: string) {
  const icons: Record<string, string> = {
    "grid-2x2":    "▦",
    trophy:        "🏆",
    shield:        "🛡️",
    users:         "👥",
    calendar:      "📅",
    "map-pin":     "📍",
    scale:         "⚖️",
    "credit-card": "💳",
    user:          "👤",
    settings:      "⚙️",
  };
  return icons[name] ?? "·";
}

const navGroups = [
  {
    label: "Overview",
    items: [
      { id: "dashboard",   label: "Dashboard",   href: "/dashboard",      icon: "grid-2x2", count: undefined },
      { id: "tournaments", label: "Tournaments",  href: "/tournaments",    icon: "trophy",   count: "3" },
      { id: "teams",       label: "Teams",        href: "/teams",          icon: "shield",   count: "128" },
    ],
  },
  {
    label: "Logistics",
    items: [
      { id: "schedule",  label: "Schedule",       href: "/teams/1/schedule", icon: "calendar",      count: undefined },
      { id: "venues",    label: "Venues & Fields", href: "/venues",           icon: "map-pin",       count: undefined },
      { id: "referees",  label: "Referees",        href: "/referees",         icon: "scale",         count: undefined },
      { id: "payments",  label: "Payments",        href: "/payments",         icon: "credit-card",   count: undefined },
    ],
  },
  {
    label: "Account",
    items: [
      { id: "profile",  label: "My Profile", href: "/profile",        icon: "user",     count: undefined },
      { id: "settings", label: "Settings",   href: "/settings",        icon: "settings", count: undefined },
    ],
  },
];
---

<!--
  On mobile/tablet (< lg): fixed overlay, starts off-screen (-translate-x-full),
  toggled to translate-x-0 by the hamburger button in AppLayout.
  On desktop (lg+): sticky, always visible.
  h-screen (not min-h-screen) pins the aside to the viewport so the nav scrolls
  internally and the user footer stays visible.
-->
<aside
  id="sidebar"
  class="fixed lg:sticky inset-y-0 left-0 z-50 w-[248px] shrink-0 flex flex-col bg-(--color-surface) border-r border-(--color-border) h-screen -translate-x-full lg:translate-x-0 transition-transform duration-200"
>
  <!-- Brand -->
  <div class="flex items-center gap-2.5 px-5 py-5 border-b border-(--color-border)">
    <BrandMark size="sm" />
    <span class="font-display font-bold text-[17px] text-(--color-foreground) flex-1">Kickoff</span>
    <!-- Close button — mobile/tablet only -->
    <button
      id="sidebar-close"
      class="lg:hidden flex items-center justify-center w-8 h-8 rounded-md text-(--color-muted) hover:bg-(--color-border-soft) hover:text-(--color-foreground) transition-colors"
      aria-label="Close menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Nav -->
  <nav class="flex-1 px-3 py-4 overflow-y-auto">
    {navGroups.map((group, gi) => (
      <div class:list={["mb-1", gi > 0 && "mt-3"]}>
        <p class="px-3 py-2 text-[11px] font-semibold uppercase tracking-wider text-(--color-muted-fg)">
          {group.label}
        </p>
        {group.items.map((item) => (
          <a
            href={item.href}
            class:list={[
              "flex items-center gap-3 px-3 py-2 rounded-[8px] text-sm font-medium mb-0.5 transition-colors",
              activeNav === item.id
                ? "bg-(--color-primary-subtle) text-(--color-primary)"
                : "text-(--color-muted) hover:bg-(--color-border-soft) hover:text-(--color-foreground)",
            ]}
          >
            <span class="text-base leading-none">{getIcon(item.icon)}</span>
            <span class="flex-1">{item.label}</span>
            {item.count && (
              <span class="text-[11px] bg-(--color-border-soft) text-(--color-muted) px-1.5 py-0.5 rounded-full">
                {item.count}
              </span>
            )}
          </a>
        ))}
      </div>
    ))}
  </nav>

  <!-- User footer -->
  <div class="p-3 border-t border-(--color-border)">
    <UserMenu
      client:load
      name={displayName}
      email={user?.email ?? ""}
      role={role}
      initials={initials}
    />
  </div>
</aside>
